# Azure OpenAI Configuration for PyRIT Validation
# This is an EXAMPLE file - copy it to user.env and fill in your actual credentials
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to user.env
# 2. Edit user.env with your actual Azure OpenAI credentials
# 3. NEVER commit user.env to git (it's in .gitignore)
#
# The validation runner loads user.env automatically when it exists in the skill root.
# To verify variables after loading, run:
#   echo $env:OPENAI_CHAT_ENDPOINT
#   echo $env:OPENAI_CHAT_KEY
#   echo $env:OPENAI_CHAT_MODEL
#
OPENAI_CHAT_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/openai/v1
OPENAI_CHAT_KEY=YOUR-AZURE-OPENAI-API-KEY-HERE
OPENAI_CHAT_MODEL=gpt-4.1
